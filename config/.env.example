# FinMetrics Environment Configuration
# =====================================
# Copy this file to config/.env and populate before running.
# NEVER commit .env to git — it is in .gitignore.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finmetrics_db
DB_USER=finmetrics
DB_PASSWORD=your_password_here

# ── EDGAR ─────────────────────────────────────────────────────────────────────
# Required by SEC. Format: "AppName your@email.com"
# Requests without this header return HTTP 403.
EDGAR_USER_AGENT=FinMetrics your@email.com

# ── Pipeline ──────────────────────────────────────────────────────────────────
# Set to true to parse + validate without writing to database
DRY_RUN=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FILE=logs/finmetrics.log  # Uncomment to write logs to file
