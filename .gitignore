# Environment — never commit credentials
config/.env
*.env

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.venv/
venv/

# Data files — raw data not committed (too large; pulled by pipeline)
data/raw/
data/processed/
*.parquet
*.csv
*.json.gz

# Reference data is committed (small, stable)
!data/reference/

# Logs
logs/
*.log

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Power BI — pbix files tracked separately (large binary)
*.pbix
